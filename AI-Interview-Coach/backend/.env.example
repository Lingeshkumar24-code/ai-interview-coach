# ---------------------------------------------------------
# AI Interview Coach — Backend Environment Variables
# Copy this file to `.env` and adjust values for your setup
# ---------------------------------------------------------

# PostgreSQL connection
POSTGRES_USER=interview_user
POSTGRES_PASSWORD=interview_pass
POSTGRES_DB=ai_interview_coach
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

DATABASE_URL=postgresql://interview_user:interview_pass@localhost:5432/ai_interview_coach

# Ollama / Qwen3 LLM settings
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:8b
OLLAMA_TIMEOUT=120

# FastAPI app settings
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# File uploads
MAX_RESUME_SIZE_MB=10
UPLOAD_DIR=./uploads
